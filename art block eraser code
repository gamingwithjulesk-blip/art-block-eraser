            "cat", "robot", "tree", "castle", "dragon", "fox", "alien", "wizard", "owl", "fish"
        ]
        self.actions = [
            "dancing", "sleeping", "flying", "reading", "singing", "exploring", "playing chess", "painting", "cooking", "surfing"
        ]
        self.styles = [
            "in a cartoon style", "as a silhouette", "with neon colors", "in the rain", "as a doodle", "cubist", "minimalist", "realistic", "abstract", "pixel art"
        ]
        self.moods = [
            "happy", "mysterious", "melancholic", "energetic", "dreamy", "spooky", "peaceful", "chaotic", "romantic", "adventurous"
        ]
        self.settings = [
            "in a forest", "on the moon", "underwater", "in a city", "at a carnival", "in a desert", "on a mountain", "in a library", "in a futuristic world", "in a magical land"
        ]
        self.mediums = [
