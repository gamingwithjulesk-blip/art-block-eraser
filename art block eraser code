            if item not in self.get_all_categories()[category]:
                self.get_all_categories()[category].append(item)
                return True
        return False


    def remove_item(self, category, item):
        if category in self.get_all_categories():
            if item in self.get_all_categories()[category]:
                self.get_all_categories()[category].remove(item)
                return True
        return False

