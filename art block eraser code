        ]

         def generate(self, subjects=None, actions=None, styles=None, moods=None, settings=None, mediums=None):
        parts = []

        if moods:
            parts.append(" and ".join(moods))
        if subjects:
            parts.append(" and ".join(subjects))
        if actions:
            parts.append(" and ".join(actions))
        if styles:
            parts.append(" and ".join(styles))

             prompt = "Draw "
        if parts:
            prompt += " ".join(parts)
        else:
            prompt += "something interesting"

        if settings:
            prompt += ", " + " and ".join(settings)

        if mediums:
            prompt += ", using " + " and ".join(mediums)

        prompt += "."
        return prompt

